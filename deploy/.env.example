# Copy this file to .env in the deploy/ directory and fill in real values.
# Then run: docker-compose --env-file .env up

# Required: CORS origin for the kiosk frontend.
# Must be the exact origin (scheme + hostname + optional port) served to browsers.
# Example: http://192.168.1.100 or https://kiosk.example.gov.cn
CORS_ORIGIN=http://YOUR_KIOSK_HOST_HERE
