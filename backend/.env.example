# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Application ──────────────────────────────────────────────────────────────
PORT=3100
NODE_ENV=development

# ── CORS (required in production, optional in development) ───────────────────
# CORS_ORIGIN=http://YOUR_KIOSK_HOST_HERE

# ── Database dialect ─────────────────────────────────────────────────────────
# DB_DIALECT=mysql      # mysql (default) | highgo
#                       # mysql  → TypeORM mysql driver  (dev: MySQL 8)
#                       # highgo → TypeORM postgres driver (prod: HighGo/瀚高)
# Unknown value causes immediate startup failure.

# ── MySQL 8 (development) ────────────────────────────────────────────────────
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=touch_kiosk_dev_user
DB_PASS=YOUR_DB_PASSWORD
DB_NAME=touch_kiosk_dev

# ── MySQL 8 dedicated integration-test database ─────────────────────────────
# This account must have privileges only on touch_kiosk_test.
MYSQL_TEST_HOST=127.0.0.1
MYSQL_TEST_PORT=3306
MYSQL_TEST_USER=touch_kiosk_test_user
MYSQL_TEST_PASS=YOUR_TEST_DB_PASSWORD
MYSQL_TEST_DATABASE=touch_kiosk_test
MYSQL_TEST_CONFIRM=touch_kiosk_test:touch_kiosk_test_user

# ── HighGo / 瀚高 (production) ───────────────────────────────────────────────
# HighGo is PostgreSQL-compatible; the backend uses the standard pg driver.
# Default port is 5866 (HighGo default); adjust if your instance differs.
#
# DB_DIALECT=highgo
# DB_HOST=YOUR_HIGHGO_HOST
# DB_PORT=5866
# DB_USER=YOUR_HIGHGO_USER
# DB_PASS=YOUR_HIGHGO_PASSWORD
# DB_NAME=touch_kiosk
# DB_SCHEMA=public           # optional: schema name (default: public)
#
# ── HighGo SSL ───────────────────────────────────────────────────────────────
# DB_SSL=false               # optional: enable SSL (true/false, default false)
#
# When DB_SSL=true the server certificate is verified by default
# (rejectUnauthorized: true). This is the secure and recommended setting.
#
# DB_SSL_INSECURE=false      # WARNING: setting to true disables cert verification.
#                            # Only use for HighGo instances with self-signed certs
#                            # in non-production environments, with explicit DBA approval.
#                            # Never set to true in production.

# ── JWT ──────────────────────────────────────────────────────────────────────
# JWT_SECRET is REQUIRED in production. Missing value causes startup failure.
# Use a cryptographically random secret of at least 32 characters.
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_IN_PRODUCTION
JWT_EXPIRES_IN=8h

# ── Service Guide (大数据共享平台办事指南上游) ───────────────────────────────
# Provider 选择（群众端不得传入上游参数，仅后端配置生效）
#
# SERVICE_GUIDE_PROVIDER=development   # 开发/测试默认；使用 DevelopmentMock（示例数据）
# SERVICE_GUIDE_PROVIDER=real            # 生产必须显式配置；需 SERVICE_GUIDE_UPSTREAM_BASE_URL
#
# 生产环境（NODE_ENV=production）限制：
#   - 未设置 SERVICE_GUIDE_PROVIDER 时启动失败（禁止默认 development mock）
#   - SERVICE_GUIDE_PROVIDER=development 时启动失败
#   - real 模式必须提供 SERVICE_GUIDE_UPSTREAM_BASE_URL
#
# 开发/测试环境（NODE_ENV=development 或 test）：
#   - 未设置时默认 development mock
#
SERVICE_GUIDE_PROVIDER=development
# SERVICE_GUIDE_UPSTREAM_BASE_URL=https://YOUR_SHARED_PLATFORM_HOST
SERVICE_GUIDE_UPSTREAM_TIMEOUT_MS=5000
